{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      },
      "suspicious": {
        "noConsole": "error",
        "noExplicitAny": "error",
        "noVar": "error"
      },
      "style": {
        "useConst": "error",
        "noNonNullAssertion": "error",
        "useFilenamingConvention": {
          "level": "error",
          "options": { "filenameCases": ["kebab-case"] }
        },
        "useNamingConvention": {
          "level": "error",
          "options": {
            "conventions": [
              { "selector": { "kind": "class" }, "formats": ["PascalCase"] },
              { "selector": { "kind": "interface" }, "formats": ["PascalCase"] },
              { "selector": { "kind": "typeAlias" }, "formats": ["PascalCase"] },
              { "selector": { "kind": "enum" }, "formats": ["PascalCase"] },
              { "selector": { "kind": "function" }, "formats": ["camelCase"] },
              { "selector": { "kind": "variable" }, "formats": ["camelCase", "CONSTANT_CASE"] },
              { "selector": { "kind": "classMethod" }, "formats": ["camelCase"] },
              { "selector": { "kind": "objectLiteralMethod" }, "formats": ["camelCase"] },
              { "selector": { "kind": "classProperty" }, "formats": ["camelCase"] },
              { "selector": { "kind": "typeProperty" }, "formats": ["camelCase"] },
              { "selector": { "kind": "typeMethod" }, "formats": ["camelCase"] },
              { "selector": { "kind": "enumMember" }, "formats": ["PascalCase", "CONSTANT_CASE"] }
            ]
          }
        }
      },
      "complexity": {
        "noForEach": "warn",
        "useFlatMap": "error"
      }
    }
  },
  "files": {
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "!**/authors- JM.js",
      "!**/dist"
    ]
  }
}
