{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      },
      "suspicious": {
        "noConsole": "error",
        "noExplicitAny": "error",
        "noVar": "error"
      },
      "style": {
        "useConst": "error",
        "noNonNullAssertion": "error"
      },
      "complexity": {
        "noForEach": "warn",
        "useFlatMap": "error"
      }
    }
  },
  "files": {
    "includes": ["**/*.ts", "**/*.tsx", "**/*.json"]
  }
}
